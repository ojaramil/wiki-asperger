---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import NotaClinica from '../components/NotaClinica.astro';
import EcosistemaLinks from '../components/EcosistemaLinks.astro';
import '../styles/global.css';

const { title, description, slug, cluster, bloques, schema_questions } = Astro.props;

// Mapear cluster string completo (del frontmatter) → color
const clusterColorMap: Record<string, string> = {
  'Fundamentos del perfil Asperger':  '#2563eb',
  'Comunicación Asperger':            '#0d9488',
  'Experiencia interna Asperger':     '#7c3aed',
  'Vida social Asperger':             '#d97706',
  'Relaciones y pareja Asperger':     '#e11d48',
  'Trabajo y vida adulta Asperger':   '#16a34a',
  'Diagnóstico Asperger':             '#ea580c',
  'Regulación emocional Asperger':    '#9333ea',
};

const clusterLabelMap: Record<string, string> = {
  'Fundamentos del perfil Asperger':  'Fundamentos',
  'Comunicación Asperger':            'Comunicación',
  'Experiencia interna Asperger':     'Experiencia interna',
  'Vida social Asperger':             'Vida social',
  'Relaciones y pareja Asperger':     'Relaciones y pareja',
  'Trabajo y vida adulta Asperger':   'Trabajo y vida adulta',
  'Diagnóstico Asperger':             'Diagnóstico',
  'Regulación emocional Asperger':    'Regulación emocional',
};

const clusterColor = cluster ? (clusterColorMap[cluster] ?? '#0d9488') : '#0d9488';
const clusterLabel = cluster ? (clusterLabelMap[cluster] ?? cluster) : '';

let faqSchema = '';
if (schema_questions && schema_questions.length > 0) {
  faqSchema = `{
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [` + schema_questions.map((q: any) => `
      {
        "@type": "Question",
        "name": "${q.question.replace(/"/g, '\\"')}",
        "acceptedAnswer": { "@type": "Answer", "text": "${q.answer.replace(/"/g, '\\"')}" }
      }`).join(',') + `
    ]
  }`;
}
---
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} | Asperger para Asperger</title>
  <meta name="description" content={description} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="canonical" href={`https://wiki.aspergerparaasperger.org/${slug}`} />
  <meta property="og:title" content={`${title} | Asperger para Asperger`} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={`https://wiki.aspergerparaasperger.org/${slug}`} />
  <meta property="og:type" content="article" />

  <script type="application/ld+json" set:html={`
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "${title}",
    "description": "${description}",
    "url": "https://wiki.aspergerparaasperger.org/${slug}",
    "publisher": {
      "@type": "Organization",
      "name": "Asperger para Asperger",
      "url": "https://www.aspergerparaasperger.org"
    }
  }
  `} />

  {faqSchema && <script type="application/ld+json" set:html={faqSchema} />}
</head>
<body>
  <Header />
  <main>
    <div class="wiki-container">
      <article class="wiki-article" style={`--cluster-color: ${clusterColor}`}>

        {clusterLabel && (
          <div class="article-meta">
            <span
              class="cluster-badge"
              style={`color: ${clusterColor}; background: ${clusterColor}18; border-color: ${clusterColor}35`}
            >
              ● {clusterLabel}
            </span>
          </div>
        )}

        <slot />

        <EcosistemaLinks bloques={bloques || []} />
        <NotaClinica />
      </article>
    </div>
  </main>
  <Footer />
</body>
</html>

<style>
/* ── Contenedor ─────────────────────────────── */
.wiki-container {
  max-width: 760px;
  margin: 0 auto;
  padding: 48px 24px 80px;
}

/* ── Badge de cluster ───────────────────────── */
.article-meta {
  margin-bottom: 24px;
}

.cluster-badge {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  font-size: 11px;
  font-weight: 600;
  font-family: var(--font-body);
  padding: 4px 12px;
  border-radius: 20px;
  border: 1px solid;
  letter-spacing: 0.04em;
  text-transform: uppercase;
}

/* ── Tipografía del artículo ────────────────── */

.wiki-article h1 {
  font-size: clamp(26px, 4vw, 40px);
  font-weight: 800;
  color: var(--text-primary);
  line-height: 1.15;
  letter-spacing: -0.02em;
  margin-bottom: 16px;
}

.wiki-article h2 {
  font-size: 12px;
  font-weight: 700;
  color: var(--cluster-color, var(--accent));
  text-transform: uppercase;
  letter-spacing: 0.1em;
  margin-top: 44px;
  margin-bottom: 16px;
  padding-bottom: 10px;
  border-bottom: 2px solid var(--bg-tertiary);
  font-family: var(--font-body);
}

.wiki-article h3 {
  font-size: 17px;
  font-weight: 700;
  color: var(--text-primary);
  margin-top: 28px;
  margin-bottom: 10px;
}

.wiki-article p {
  font-size: 16px;
  color: var(--text-secondary);
  margin-bottom: 18px;
  line-height: 1.8;
}

/* Definición destacada — primer párrafo */
.wiki-article > p:first-of-type {
  font-size: 17px;
  font-weight: 400;
  color: var(--text-primary);
  line-height: 1.75;
  background: var(--bg-secondary);
  border-left: 4px solid var(--cluster-color, var(--accent));
  padding: 20px 24px;
  border-radius: 0 var(--radius-md) var(--radius-md) 0;
  margin-bottom: 36px;
}

/* Links */
.wiki-article a {
  color: var(--cluster-color, var(--accent));
  text-decoration: none;
  font-weight: 500;
  border-bottom: 1px solid transparent;
  transition: border-color 0.2s;
}

.wiki-article a:hover {
  border-bottom-color: var(--cluster-color, var(--accent));
}

/* Strong */
.wiki-article strong {
  color: var(--text-primary);
  font-weight: 600;
}

/* Listas */
.wiki-article ul {
  list-style: none;
  margin-bottom: 18px;
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.wiki-article ul li {
  font-size: 15px;
  color: var(--text-secondary);
  padding-left: 22px;
  position: relative;
  line-height: 1.7;
}

.wiki-article ul li::before {
  content: '→';
  position: absolute;
  left: 0;
  color: var(--cluster-color, var(--accent));
  font-size: 13px;
  top: 3px;
}

/* HR */
.wiki-article hr {
  border: none;
  border-top: 1px solid var(--border-subtle);
  margin: 40px 0;
}

@media (max-width: 640px) {
  .wiki-container { padding: 32px 20px 60px; }
  .wiki-article > p:first-of-type { padding: 16px 18px; font-size: 15px; }
  .wiki-article h1 { font-size: 26px; }
}
</style>