---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import NotaClinica from '../components/NotaClinica.astro';
import EcosistemaLinks from '../components/EcosistemaLinks.astro';
import '../styles/global.css';

const { title, description, slug, cluster, bloques, schema_questions } = Astro.props;

const clusterColorMap: Record<string, string> = {
  'Fundamentos del perfil Asperger':  '#2563eb',
  'Comunicación Asperger':            '#0d9488',
  'Experiencia interna Asperger':     '#7c3aed',
  'Vida social Asperger':             '#d97706',
  'Relaciones y pareja Asperger':     '#e11d48',
  'Trabajo y vida adulta Asperger':   '#16a34a',
  'Diagnóstico Asperger':             '#ea580c',
  'Regulación emocional Asperger':    '#9333ea',
};

const clusterLabelMap: Record<string, string> = {
  'Fundamentos del perfil Asperger':  'Fundamentos',
  'Comunicación Asperger':            'Comunicación',
  'Experiencia interna Asperger':     'Experiencia interna',
  'Vida social Asperger':             'Vida social',
  'Relaciones y pareja Asperger':     'Relaciones y pareja',
  'Trabajo y vida adulta Asperger':   'Trabajo y vida adulta',
  'Diagnóstico Asperger':             'Diagnóstico',
  'Regulación emocional Asperger':    'Regulación emocional',
};

const color = cluster ? (clusterColorMap[cluster] ?? '#0d9488') : '#0d9488';
const label = cluster ? (clusterLabelMap[cluster] ?? '') : '';

let faqSchema = '';
if (schema_questions && schema_questions.length > 0) {
  faqSchema = `{
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [` + schema_questions.map((q: any) => `
      {
        "@type": "Question",
        "name": "${q.question.replace(/"/g, '\\"')}",
        "acceptedAnswer": { "@type": "Answer", "text": "${q.answer.replace(/"/g, '\\"')}" }
      }`).join(',') + `
    ]
  }`;
}
---
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} | Asperger para Asperger</title>
  <meta name="description" content={description} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="canonical" href={`https://wiki.aspergerparaasperger.org/${slug}`} />
  <meta property="og:title" content={`${title} | Asperger para Asperger`} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={`https://wiki.aspergerparaasperger.org/${slug}`} />
  <meta property="og:type" content="article" />

  <script type="application/ld+json" set:html={`
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "${title}",
    "description": "${description}",
    "url": "https://wiki.aspergerparaasperger.org/${slug}",
    "publisher": {
      "@type": "Organization",
      "name": "Asperger para Asperger",
      "url": "https://www.aspergerparaasperger.org"
    }
  }
  `} />

  {faqSchema && <script type="application/ld+json" set:html={faqSchema} />}
</head>
<body>
  <Header />
  <main class="main">
    <article class="article" style={`--cc: ${color}`}>

      {label && (
        <p class="article-eyebrow" style={`color: ${color}`}>{label}</p>
      )}

      <slot />

      <EcosistemaLinks bloques={bloques || []} />
      <NotaClinica />
    </article>
  </main>
  <Footer />
</body>
</html>

<style>
/* ── Layout ─────────────────────────────────── */
.main {
  padding: 56px 24px 100px;
}

.article {
  max-width: var(--content-width);
  margin: 0 auto;
}

/* ── Eyebrow del cluster ─────────────────────── */
.article-eyebrow {
  font-family: var(--font);
  font-size: 11px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.12em;
  margin-bottom: 14px;
  line-height: 1;
  /* color viene del style inline */
}

/* ── H1 — igual que títulos del sitio principal ── */
.article h1 {
  font-family: var(--font);
  font-size: clamp(26px, 5vw, 40px);
  font-weight: 800;
  color: var(--color-heading);
  line-height: 1.2;
  letter-spacing: -0.03em;
  margin-bottom: 20px;
}

/* ── H2 — label de sección, color del cluster ── */
.article h2 {
  font-family: var(--font);
  font-size: 11px;
  font-weight: 700;
  color: var(--cc);
  text-transform: uppercase;
  letter-spacing: 0.12em;
  margin-top: 52px;
  margin-bottom: 14px;
  border: none;
  padding: 0;
}

/* ── H3 — subtítulo ─────────────────────────── */
.article h3 {
  font-family: var(--font);
  font-size: 1.1rem;
  font-weight: 800;
  color: var(--color-heading);
  letter-spacing: -0.02em;
  line-height: 1.3;
  margin-top: 32px;
  margin-bottom: 10px;
}

/* ── Párrafos ────────────────────────────────── */
.article p {
  font-family: var(--font);
  font-size: 1.05rem;
  font-weight: 400;
  color: var(--color-body);
  line-height: 1.8;
  letter-spacing: -0.01em;
  margin-bottom: 20px;
}

/* ── Primer párrafo — definición destacada ── */
.article > p:first-of-type {
  font-size: 1.1rem;
  font-weight: 500;
  color: var(--color-heading);
  line-height: 1.75;
  padding-left: 18px;
  border-left: 3px solid var(--cc);
  margin-bottom: 40px;
  margin-top: 6px;
  letter-spacing: -0.015em;
}

/* ── Links ──────────────────────────────────── */
.article a {
  color: var(--color-link);
  text-decoration: none;
  font-weight: 500;
  transition: color 0.15s;
}

.article a:hover {
  color: var(--color-accent-hover);
  text-decoration: underline;
}

/* ── Strong ─────────────────────────────────── */
.article strong {
  font-weight: 700;
  color: var(--color-heading);
}

/* ── Listas ─────────────────────────────────── */
.article ul,
.article ol {
  margin-bottom: 20px;
  display: flex;
  flex-direction: column;
  gap: 8px;
  list-style: none;
}

.article ul li,
.article ol li {
  font-family: var(--font);
  font-size: 1.05rem;
  font-weight: 400;
  color: var(--color-body);
  line-height: 1.7;
  letter-spacing: -0.01em;
  padding-left: 18px;
  position: relative;
}

.article ul li::before {
  content: '–';
  position: absolute;
  left: 0;
  color: var(--cc);
  font-weight: 700;
}

.article ol { counter-reset: item; }

.article ol li::before {
  content: counter(item) '.';
  counter-increment: item;
  position: absolute;
  left: 0;
  color: var(--cc);
  font-weight: 700;
  font-size: 0.9rem;
}

/* ── HR ─────────────────────────────────────── */
.article hr {
  border: none;
  border-top: 1px solid var(--border);
  margin: 48px 0;
}

/* ── Em (nota clínica inline) ───────────────── */
.article > em {
  display: block;
  font-style: italic;
  font-size: 0.82rem;
  font-weight: 400;
  color: var(--color-muted);
  line-height: 1.7;
  letter-spacing: 0;
  padding-top: 28px;
  margin-top: 52px;
  border-top: 1px solid var(--border);
}

/* ── Blockquote ─────────────────────────────── */
.article blockquote {
  border-left: 3px solid var(--border);
  padding: 2px 0 2px 18px;
  margin: 28px 0;
}

.article blockquote p {
  font-size: 0.95rem;
  color: var(--color-muted);
  margin-bottom: 6px;
  font-weight: 400;
}

.article blockquote p:last-child { margin-bottom: 0; }

/* ── Responsive ─────────────────────────────── */
@media (max-width: 640px) {
  .main { padding: 36px 20px 80px; }
  .article > p:first-of-type { font-size: 1.05rem; }
  .article h1 { font-size: 26px; }
}
</style>