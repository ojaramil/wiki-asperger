---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import NotaClinica from '../components/NotaClinica.astro';
import EcosistemaLinks from '../components/EcosistemaLinks.astro';
import '../styles/global.css';

const { title, description, slug, cluster, bloques, schema_questions } = Astro.props;

// Cluster string completo del frontmatter → color hex
const clusterColorMap: Record<string, string> = {
  'Fundamentos del perfil Asperger':  '#2563eb',
  'Comunicación Asperger':            '#0d9488',
  'Experiencia interna Asperger':     '#7c3aed',
  'Vida social Asperger':             '#d97706',
  'Relaciones y pareja Asperger':     '#e11d48',
  'Trabajo y vida adulta Asperger':   '#16a34a',
  'Diagnóstico Asperger':             '#ea580c',
  'Regulación emocional Asperger':    '#9333ea',
};

const clusterLabelMap: Record<string, string> = {
  'Fundamentos del perfil Asperger':  'Fundamentos',
  'Comunicación Asperger':            'Comunicación',
  'Experiencia interna Asperger':     'Experiencia interna',
  'Vida social Asperger':             'Vida social',
  'Relaciones y pareja Asperger':     'Relaciones y pareja',
  'Trabajo y vida adulta Asperger':   'Trabajo y vida adulta',
  'Diagnóstico Asperger':             'Diagnóstico',
  'Regulación emocional Asperger':    'Regulación emocional',
};

const color = cluster ? (clusterColorMap[cluster] ?? '#0d9488') : '#0d9488';
const label = cluster ? (clusterLabelMap[cluster] ?? '') : '';

let faqSchema = '';
if (schema_questions && schema_questions.length > 0) {
  faqSchema = `{
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [` + schema_questions.map((q: any) => `
      {
        "@type": "Question",
        "name": "${q.question.replace(/"/g, '\\"')}",
        "acceptedAnswer": { "@type": "Answer", "text": "${q.answer.replace(/"/g, '\\"')}" }
      }`).join(',') + `
    ]
  }`;
}
---
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} | Asperger para Asperger</title>
  <meta name="description" content={description} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="canonical" href={`https://wiki.aspergerparaasperger.org/${slug}`} />
  <meta property="og:title" content={`${title} | Asperger para Asperger`} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={`https://wiki.aspergerparaasperger.org/${slug}`} />
  <meta property="og:type" content="article" />

  <script type="application/ld+json" set:html={`
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "${title}",
    "description": "${description}",
    "url": "https://wiki.aspergerparaasperger.org/${slug}",
    "publisher": {
      "@type": "Organization",
      "name": "Asperger para Asperger",
      "url": "https://www.aspergerparaasperger.org"
    }
  }
  `} />

  {faqSchema && <script type="application/ld+json" set:html={faqSchema} />}
</head>
<body>
  <Header />
  <main class="main">
    <article class="article" style={`--cc: ${color}`}>

      {label && (
        <div class="article-cluster">
          <span class="cluster-label" style={`color: ${color}`}>
            {label}
          </span>
        </div>
      )}

      <slot />

      <EcosistemaLinks bloques={bloques || []} />
      <NotaClinica />
    </article>
  </main>
  <Footer />
</body>
</html>

<style>
/* ── Layout ─────────────────────────────────── */
.main {
  padding: 56px 24px 100px;
}

.article {
  max-width: var(--content-width);
  margin: 0 auto;
}

/* ── Cluster label — solo texto, sin badge ── */
.article-cluster {
  margin-bottom: 20px;
}

.cluster-label {
  font-size: 12px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  font-family: var(--font-mono);
}

/* ── H1 — título ────────────────────────────── */
.article h1 {
  font-size: clamp(28px, 5vw, 42px);
  font-weight: 800;
  color: var(--text-primary);
  line-height: 1.2;
  letter-spacing: -0.025em;
  margin-bottom: 24px;
}

/* ── H2 — secciones ─────────────────────────── */
.article h2 {
  font-size: 11px;
  font-weight: 700;
  color: var(--cc);
  text-transform: uppercase;
  letter-spacing: 0.12em;
  margin-top: 52px;
  margin-bottom: 16px;
  font-family: var(--font);
  border: none;
  padding: 0;
}

/* ── H3 — subsecciones ──────────────────────── */
.article h3 {
  font-size: 18px;
  font-weight: 700;
  color: var(--text-primary);
  margin-top: 32px;
  margin-bottom: 12px;
}

/* ── Párrafos ────────────────────────────────── */
.article p {
  font-size: 17px;
  color: var(--text-secondary);
  line-height: var(--reading-lh);
  margin-bottom: 20px;
}

/* ── Primer párrafo — definición ─────────────── */
.article > p:first-of-type {
  font-size: 18px;
  color: var(--text-primary);
  font-weight: 400;
  line-height: 1.75;
  padding-left: 20px;
  border-left: 3px solid var(--cc);
  margin-bottom: 40px;
  margin-top: 8px;
}

/* ── Links ──────────────────────────────────── */
.article a {
  color: var(--cc);
  text-decoration: none;
  font-weight: 500;
  border-bottom: 1px solid transparent;
  transition: border-color 0.15s;
}

.article a:hover {
  border-bottom-color: var(--cc);
}

/* ── Strong ─────────────────────────────────── */
.article strong {
  color: var(--text-primary);
  font-weight: 600;
}

/* ── Listas ─────────────────────────────────── */
.article ul {
  list-style: none;
  margin-bottom: 20px;
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.article ul li {
  font-size: 16px;
  color: var(--text-secondary);
  line-height: 1.7;
  padding-left: 18px;
  position: relative;
}

.article ul li::before {
  content: '–';
  position: absolute;
  left: 0;
  color: var(--cc);
  font-weight: 700;
}

/* ── HR ─────────────────────────────────────── */
.article hr {
  border: none;
  border-top: 1px solid var(--border);
  margin: 48px 0;
}

/* ── Em (nota clínica inline si aplica) ─────── */
.article > em {
  display: block;
  font-size: 13px;
  font-style: normal;
  color: var(--text-light);
  line-height: 1.7;
  padding-top: 28px;
  margin-top: 52px;
  border-top: 1px solid var(--border);
}

/* ── Blockquote (bloques ecosistema) ────────── */
.article blockquote {
  border-left: 3px solid var(--border);
  padding: 4px 0 4px 20px;
  margin: 32px 0;
}

.article blockquote p {
  font-size: 15px;
  color: var(--text-muted);
  margin-bottom: 8px;
}

.article blockquote p:last-child { margin-bottom: 0; }

/* ── Responsive ─────────────────────────────── */
@media (max-width: 640px) {
  .main { padding: 40px 20px 80px; }
  .article > p:first-of-type { font-size: 17px; }
  .article h1 { font-size: 28px; }
}
</style>