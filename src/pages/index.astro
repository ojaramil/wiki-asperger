---
import RootLayout from '../layouts/RootLayout.astro';
import { getCollection } from 'astro:content';

const entradas = await getCollection('wiki');

const clusters = [
  { name: "Fundamentos del perfil Asperger", color: "#2563eb" },
  { name: "Comunicación Asperger",            color: "#0d9488" },
  { name: "Experiencia interna Asperger",     color: "#7c3aed" },
  { name: "Vida social Asperger",             color: "#d97706" },
  { name: "Relaciones y pareja Asperger",     color: "#e11d48" },
  { name: "Trabajo y vida adulta Asperger",   color: "#16a34a" },
  { name: "Diagnóstico Asperger",             color: "#ea580c" },
  { name: "Regulación emocional Asperger",    color: "#9333ea" },
];

function getEntradasByCluster(clusterName: string) {
  return entradas.filter(e => e.data.cluster === clusterName);
}
---

<RootLayout
  title="Base de conocimiento sobre el perfil Asperger en español"
  description="El Asperger como identidad neurocognitiva — desde la experiencia real. Wiki, comunidad e inclusión completa."
>
  <!-- Hero -->
  <section class="hero">
    <span class="hero-eyebrow">wiki · asperger para asperger</span>
    <h1 class="hero-title">Base de conocimiento sobre el perfil Asperger.</h1>
    <p class="hero-desc">
      Sin lenguaje clínico. Sin plantillas. Desde la experiencia real.
      Un recurso creado por personas Asperger para personas Asperger.
    </p>
    <a
      href="https://www.aspergerparaasperger.org/grupo-club-social-y-educativo-virtual-asperger-para-asperger/"
      class="hero-cta"
    >
      Unirme al Club →
    </a>
  </section>

  <!-- Buscador -->
  <div class="search-section">
    <input
      type="text"
      id="searchInput"
      class="search-input"
      placeholder="Buscar en la wiki..."
      autocomplete="off"
      spellcheck="false"
    />
  </div>

  <!-- Clusters -->
  <div class="clusters" id="clustersContainer">
    <span class="clusters-eyebrow">Explorar por área</span>
    {clusters.map(cluster => {
      const items = getEntradasByCluster(cluster.name);
      if (items.length === 0) return null;
      return (
        <div
          class="cluster-group"
          style={`--cc: ${cluster.color}`}
          data-cluster={cluster.name}
        >
          <h2 class="cluster-title">{cluster.name}</h2>
          <div class="cluster-links">
            {items.map(entrada => (
              <a href={`/${entrada.slug}`} class="node-link">
                {entrada.data.title}
              </a>
            ))}
          </div>
        </div>
      );
    })}
  </div>

  <script>
    const searchInput = document.getElementById('searchInput') as HTMLInputElement;
    const groups = document.querySelectorAll('.cluster-group') as NodeListOf<HTMLElement>;

    if (searchInput) {
      searchInput.addEventListener('input', () => {
        const term = searchInput.value.toLowerCase().trim();
        groups.forEach(group => {
          const links = group.querySelectorAll('.node-link') as NodeListOf<HTMLElement>;
          let anyVisible = false;
          links.forEach(link => {
            const match = !term || (link.textContent || '').toLowerCase().includes(term);
            link.style.display = match ? '' : 'none';
            if (match) anyVisible = true;
          });
          group.style.display = term === '' ? '' : (anyVisible ? '' : 'none');
        });
      });
    }
  </script>
</RootLayout>

<style>
/* ── Hero ─────────────────────────────────── */
.hero {
  max-width: calc(var(--content-width) + 48px);
  margin: 0 auto;
  padding: 72px 24px 52px;
  border-bottom: 1px solid var(--border);
}

.hero-eyebrow {
  font-family: var(--font);
  font-size: 11px;
  font-weight: 700;
  color: var(--color-accent);
  text-transform: uppercase;
  letter-spacing: 0.12em;
  display: block;
  margin-bottom: 16px;
}

.hero-title {
  font-family: var(--font);
  font-size: clamp(28px, 5vw, 44px);
  font-weight: 800;
  color: var(--color-heading);
  line-height: 1.15;
  letter-spacing: -0.03em;
  margin-bottom: 16px;
  max-width: 620px;
}

.hero-desc {
  font-family: var(--font);
  font-size: 1.05rem;
  font-weight: 400;
  color: var(--color-body);
  line-height: 1.8;
  letter-spacing: -0.01em;
  max-width: 520px;
  margin-bottom: 32px;
}

.hero-cta {
  display: inline-block;
  background: var(--color-accent);
  color: white;
  font-family: var(--font);
  font-size: 0.92rem;
  font-weight: 700;
  padding: 10px 22px;
  border-radius: 6px;
  text-decoration: none;
  transition: background 0.2s;
}

.hero-cta:hover {
  background: var(--color-accent-hover);
  color: white;
  text-decoration: none;
}

/* ── Buscador ─────────────────────────────── */
.search-section {
  max-width: calc(var(--content-width) + 48px);
  margin: 0 auto;
  padding: 40px 24px 0;
}

.search-input {
  width: 100%;
  max-width: 440px;
  background: white;
  border: 1px solid var(--border);
  border-radius: 6px;
  padding: 10px 16px;
  font-family: var(--font);
  font-size: 0.95rem;
  font-weight: 400;
  color: var(--color-heading);
  letter-spacing: -0.01em;
  outline: none;
  transition: border-color 0.2s;
}

.search-input:focus { border-color: var(--color-accent); }
.search-input::placeholder { color: var(--color-muted); }

/* ── Clusters ─────────────────────────────── */
.clusters {
  max-width: calc(var(--content-width) + 48px);
  margin: 0 auto;
  padding: 44px 24px 80px;
}

.clusters-eyebrow {
  font-family: var(--font);
  font-size: 11px;
  font-weight: 700;
  color: var(--color-muted);
  text-transform: uppercase;
  letter-spacing: 0.12em;
  display: block;
  margin-bottom: 32px;
}

.cluster-group {
  margin-bottom: 36px;
  padding-bottom: 36px;
  border-bottom: 1px solid var(--border);
}

.cluster-group:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.cluster-title {
  font-family: var(--font);
  font-size: 11px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.12em;
  color: var(--cc);
  margin-bottom: 14px;
  border: none;
  padding: 0;
  margin-top: 0;
}

.cluster-links {
  display: flex;
  flex-wrap: wrap;
  column-gap: 24px;
  row-gap: 4px;
}

.cluster-links a.node-link {
  font-family: var(--font);
  font-size: 1rem;
  font-weight: 500;
  color: var(--color-body);
  text-decoration: none;
  padding: 4px 0;
  width: calc(50% - 12px);
  display: block;
  transition: color 0.15s;
  letter-spacing: -0.01em;
}

.cluster-links a.node-link:hover {
  color: var(--color-link);
  text-decoration: none;
}

/* ── Responsive ──────────────────────────── */
@media (max-width: 480px) {
  .hero { padding: 48px 20px 40px; }
  .clusters { padding: 36px 20px 60px; }
  .search-section { padding: 28px 20px 0; }
  .cluster-links a.node-link { width: 100%; }
}
</style>
