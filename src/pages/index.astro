---
import RootLayout from '../layouts/RootLayout.astro';
import { getCollection } from 'astro:content';

const entradas = await getCollection('wiki');

const clusters = [
  { name: "Fundamentos del perfil Asperger", color: "#2563eb" },
  { name: "Comunicación Asperger",            color: "#0d9488" },
  { name: "Experiencia interna Asperger",     color: "#7c3aed" },
  { name: "Vida social Asperger",             color: "#d97706" },
  { name: "Relaciones y pareja Asperger",     color: "#e11d48" },
  { name: "Trabajo y vida adulta Asperger",   color: "#16a34a" },
  { name: "Diagnóstico Asperger",             color: "#ea580c" },
  { name: "Regulación emocional Asperger",    color: "#9333ea" },
];

function getEntradasByCluster(clusterName: string) {
  return entradas.filter(e => e.data.cluster === clusterName);
}
---

<RootLayout
  title="Base de conocimiento sobre el perfil Asperger en español"
  description="El Asperger como identidad neurocognitiva — desde la experiencia real. Wiki, comunidad e inclusión completa."
>
  <!-- Hero -->
  <section class="hero">
    <span class="hero-label">wiki · asperger para asperger</span>
    <h1 class="hero-title">El perfil Asperger desde adentro.</h1>
    <p class="hero-desc">
      Base de conocimiento sobre el perfil neurocognitivo Asperger.
      Sin lenguaje clínico. Sin plantillas. Desde la experiencia real.
    </p>
    <div class="hero-links">
      <a href="https://www.aspergerparaasperger.org/grupo-club-social-y-educativo-virtual-asperger-para-asperger/" class="hero-link-primary">
        Unirme al Club →
      </a>
      <a href="https://comunidad.aspergerparaasperger.org/invitation?code=9J8594" class="hero-link-secondary">
        Comunidad gratuita
      </a>
    </div>
  </section>

  <!-- Buscador -->
  <div class="search-section">
    <input
      type="text"
      id="searchInput"
      class="search-input"
      placeholder="Buscar en la wiki..."
      autocomplete="off"
      spellcheck="false"
    />
  </div>

  <!-- Clusters — lista plana -->
  <div class="clusters" id="clustersContainer">
    <span class="clusters-label">Explorar por área</span>
    {clusters.map(cluster => {
      const items = getEntradasByCluster(cluster.name);
      if (items.length === 0) return null;
      return (
        <div class="cluster-group" style={`--cc: ${cluster.color}`} data-cluster={cluster.name}>
          <h2 class="cluster-group-title" style={`color: ${cluster.color}`}>
            {cluster.name}
          </h2>
          <div class="cluster-group-links">
            {items.map(entrada => (
              <a href={`/${entrada.slug}`} class="node-link">
                {entrada.data.title}
              </a>
            ))}
          </div>
        </div>
      );
    })}
  </div>

  <script>
    const searchInput = document.getElementById('searchInput') as HTMLInputElement;
    const groups = document.querySelectorAll('.cluster-group') as NodeListOf<HTMLElement>;

    if (searchInput) {
      searchInput.addEventListener('input', () => {
        const term = searchInput.value.toLowerCase().trim();
        groups.forEach(group => {
          const links = group.querySelectorAll('.node-link') as NodeListOf<HTMLElement>;
          let anyVisible = false;
          links.forEach(link => {
            const match = !term || (link.textContent || '').toLowerCase().includes(term);
            link.style.display = match ? '' : 'none';
            if (match) anyVisible = true;
          });
          group.style.display = term === '' ? '' : (anyVisible ? '' : 'none');
        });
      });
    }
  </script>
</RootLayout>

<style>
/* ── Hero ─────────────────────────────────── */
.hero {
  max-width: calc(var(--content-width) + 48px);
  margin: 0 auto;
  padding: 72px 24px 48px;
  border-bottom: 1px solid var(--border);
}

.hero-label {
  font-size: 11px;
  font-weight: 700;
  color: var(--accent);
  text-transform: uppercase;
  letter-spacing: 0.12em;
  display: block;
  margin-bottom: 16px;
  font-family: var(--font-mono);
}

.hero-title {
  font-size: clamp(28px, 5vw, 44px);
  font-weight: 800;
  color: var(--text-primary);
  line-height: 1.15;
  letter-spacing: -0.025em;
  margin-bottom: 16px;
  max-width: 600px;
}

.hero-desc {
  font-size: 17px;
  color: var(--text-muted);
  line-height: 1.7;
  max-width: 520px;
  margin-bottom: 32px;
}

.hero-links {
  display: flex;
  gap: 24px;
  align-items: center;
  flex-wrap: wrap;
}

.hero-links a {
  font-size: 14px;
  font-weight: 600;
  text-decoration: none;
  transition: color 0.15s;
  border-bottom: none;
}

.hero-link-primary {
  color: var(--accent);
  border-bottom: 2px solid var(--accent) !important;
  padding-bottom: 1px;
}

.hero-link-primary:hover {
  color: var(--accent-dark);
  border-bottom-color: var(--accent-dark) !important;
}

.hero-link-secondary {
  color: var(--text-muted);
}

.hero-link-secondary:hover { color: var(--text-primary); }

/* ── Buscador ─────────────────────────────── */
.search-section {
  max-width: calc(var(--content-width) + 48px);
  margin: 0 auto;
  padding: 40px 24px 0;
}

.search-input {
  width: 100%;
  max-width: 440px;
  background: white;
  border: 1px solid var(--border);
  border-radius: 6px;
  padding: 10px 16px;
  font-family: var(--font);
  font-size: 14px;
  color: var(--text-primary);
  outline: none;
  transition: border-color 0.2s;
}

.search-input:focus { border-color: var(--accent); }
.search-input::placeholder { color: var(--text-light); }

/* ── Clusters ─────────────────────────────── */
.clusters {
  max-width: calc(var(--content-width) + 48px);
  margin: 0 auto;
  padding: 44px 24px 80px;
}

.clusters-label {
  font-size: 11px;
  font-weight: 700;
  color: var(--text-light);
  text-transform: uppercase;
  letter-spacing: 0.1em;
  display: block;
  margin-bottom: 32px;
}

.cluster-group {
  margin-bottom: 36px;
  padding-bottom: 36px;
  border-bottom: 1px solid var(--border);
}

.cluster-group:last-child {
  border-bottom: none;
  margin-bottom: 0;
  padding-bottom: 0;
}

.cluster-group-title {
  font-size: 11px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  margin-bottom: 14px;
  font-family: var(--font-mono);
}

.cluster-group-links {
  display: flex;
  flex-wrap: wrap;
  column-gap: 24px;
}

.cluster-group-links a.node-link {
  font-size: 15px;
  font-weight: 500;
  color: var(--text-secondary);
  text-decoration: none;
  padding: 4px 0;
  transition: color 0.15s;
  width: calc(50% - 12px);
  display: block;
  border-bottom: none;
}

.cluster-group-links a.node-link:hover { color: var(--cc); }

/* ── Responsive ──────────────────────────── */
@media (max-width: 480px) {
  .hero { padding: 48px 20px 40px; }
  .hero-links { flex-direction: column; gap: 12px; align-items: flex-start; }
  .hero-link-primary { border-bottom: none !important; }
  .clusters { padding: 36px 20px 60px; }
  .search-section { padding: 28px 20px 0; }
  .cluster-group-links a.node-link { width: 100%; }
}
</style>
