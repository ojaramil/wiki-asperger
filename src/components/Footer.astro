<style>
.footer {
  border-top: 1px solid var(--border);
  background: var(--bg-soft);
  margin-top: 80px;
}

.footer-inner {
  max-width: calc(var(--content-width) + 48px);
  margin: 0 auto;
  padding: 40px 24px 28px;
}

.footer-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 32px;
  margin-bottom: 28px;
  flex-wrap: wrap;
}

.footer-brand {
  font-family: var(--font);
  font-size: 14px;
  font-weight: 800;
  color: var(--color-heading);
  text-decoration: none;
  letter-spacing: -0.02em;
  white-space: nowrap;
}

.footer-brand:hover { color: var(--color-accent); text-decoration: none; }

.footer-nav {
  display: flex;
  flex-wrap: wrap;
  gap: 8px 20px;
  justify-content: flex-end;
}

.footer-nav a {
  font-family: var(--font);
  font-size: 0.88rem;
  font-weight: 500;
  color: var(--color-body);
  text-decoration: none;
  transition: color 0.15s;
}

.footer-nav a:hover { color: var(--color-link); text-decoration: none; }

.footer-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 24px;
  padding-top: 20px;
  border-top: 1px solid var(--border);
  flex-wrap: wrap;
}

.footer-bottom span {
  font-family: var(--font);
  font-size: 0.8rem;
  font-weight: 400;
  color: var(--color-muted);
}

.footer-note {
  font-style: italic;
  text-align: right;
  max-width: 380px;
}

@media (max-width: 600px) {
  .footer-top { flex-direction: column; }
  .footer-nav { justify-content: flex-start; }
  .footer-bottom { flex-direction: column; text-align: center; }
  .footer-note { text-align: center; max-width: 100%; }
}
</style>