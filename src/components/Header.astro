---
---
<header class="header">
  <div class="header-inner">
    <a href="/" class="header-logo">
      <span class="logo-main">Asperger para Asperger</span>
      <span class="logo-sep"> · </span>
      <span class="logo-wiki">Wiki</span>
    </a>
    <nav class="header-nav">
      <a href="https://www.aspergerparaasperger.org/blog">Blog</a>
      <a href="https://comunidad.aspergerparaasperger.org/invitation?code=9J8594">Comunidad</a>
      <a
        href="https://www.aspergerparaasperger.org/grupo-club-social-y-educativo-virtual-asperger-para-asperger/"
        class="header-cta"
      >Unirme al Club</a>
    </nav>
  </div>
</header>

<style>
.header {
  position: sticky;
  top: 0;
  z-index: 50;
  background: rgba(255,255,255,0.95);
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
  border-bottom: 1px solid var(--border);
}

.header-inner {
  max-width: calc(var(--content-width) + 48px);
  margin: 0 auto;
  padding: 0 24px;
  height: 60px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24px;
}

.header-logo {
  text-decoration: none;
  display: flex;
  align-items: baseline;
  gap: 0;
}

.logo-main {
  font-family: var(--font);
  font-size: 14px;
  font-weight: 800;
  color: var(--color-heading);
  letter-spacing: -0.02em;
}

.logo-sep {
  font-size: 14px;
  color: var(--border);
  font-weight: 400;
  margin: 0 2px;
}

.logo-wiki {
  font-family: var(--font);
  font-size: 14px;
  font-weight: 500;
  color: var(--color-accent);
}

.header-nav {
  display: flex;
  align-items: center;
  gap: 24px;
}

.header-nav a {
  font-family: var(--font);
  font-size: 0.92rem;
  font-weight: 700;
  color: var(--color-body);
  text-decoration: none;
  transition: color 0.2s;
}

.header-nav a:hover {
  color: var(--color-heading);
  text-decoration: none;
}

.header-cta {
  background: var(--color-accent) !important;
  color: white !important;
  padding: 8px 18px !important;
  border-radius: 6px !important;
  font-weight: 700 !important;
  font-size: 0.88rem !important;
  transition: background 0.2s !important;
}

.header-cta:hover {
  background: var(--color-accent-hover) !important;
  color: white !important;
  text-decoration: none !important;
}

@media (max-width: 600px) {
  .header-nav a:not(.header-cta) { display: none; }
  .logo-sep { display: none; }
  .logo-wiki { display: none; }
  .logo-main { font-size: 13px; }
}
</style>